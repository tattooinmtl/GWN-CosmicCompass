rules_version = '2';

// CosmicCompass Firestore security rules.
// Paste this into Firebase Console -> Firestore Database -> Rules -> Publish.
//
// Public feed (messages/comments): anyone can read, signed-in users write their own.
// Private side (users/friends/friendRequests/conversations): locked down so private
// chats are only readable/writable by their participants.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function inConversation(cid) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participants;
    }

    // ---- Public feed (unchanged) ----
    match /messages/{messageId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.authorUid == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.authorUid == request.auth.uid;
    }

    // ---- User profiles ----
    // Any signed-in user can read profiles (needed to search friends and show
    // names/avatars). Only the owner can write their own profile.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isUser(uid);

      // Friend list entries. The owner manages their own list. The OTHER user may
      // create their entry only when a matching friend request exists (which means
      // the owner invited them) -- this is the accept step. Prevents spoofing.
      match /friends/{friendUid} {
        allow read: if isUser(uid);
        allow create: if isUser(uid)
          || (isUser(friendUid)
              && exists(/databases/$(database)/documents/friendRequests/$(uid + "__" + friendUid)));
        allow delete: if isUser(uid) || isUser(friendUid);
      }
    }

    // ---- Friend requests ----
    // id is "<fromUid>__<toUid>". Sender creates; only the two parties can read;
    // recipient can accept (update); either party can delete (cancel/decline).
    match /friendRequests/{reqId} {
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && reqId == request.resource.data.fromUid + "__" + request.resource.data.toUid;
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow update: if signedIn() && resource.data.toUid == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }

    // ---- Private conversations ----
    // Readable/writable only by participants. The creator must include themselves.
    match /conversations/{cid} {
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants;
      allow read, update: if signedIn()
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if inConversation(cid);
        allow create: if inConversation(cid)
          && request.resource.data.senderUid == request.auth.uid;
        allow delete: if inConversation(cid);
      }
    }
  }
}
